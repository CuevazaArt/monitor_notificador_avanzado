# Configuración del Monitor de Anuncios y Listados

# Intervalo en segundos para la consulta de APIs
POLLING_INTERVAL=5

# Opcional: Integración con Discord (URL del Webhook)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# Opcional: Integración con Telegram (Token del Bot y ID del Chat)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
