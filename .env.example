# Configuración del Monitor de Anuncios y Listados

# Intervalo en segundos para la consulta de APIs (mínimo recomendado: 5)
POLLING_INTERVAL=5

# Opcional: Ruta de la base de datos SQLite local (por defecto: monitor.db)
DB_PATH=monitor.db

# Configuración del Reporte de Control Periódico (en horas, ej: 12 o 24)
HEARTBEAT_INTERVAL_HOURS=12

# Opcional: Integración con Discord (URL del Webhook de alertas de listados)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# Opcional: Integración con Telegram (Alertas y Reportes de Control)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
